# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Contact email (fallback for "Get in touch" if not set in Admin → Settings)
# VITE_CONTACT_EMAIL=you@example.com

# Optional: Admin without login screen (secret-key only)
# Set these to hide the admin login and protect admin by URL key only.
# VITE_ADMIN_PATH=_edit
# VITE_ADMIN_SECRET_KEY=your-long-random-secret

# Optional: Unsplash API for cover image search in project form
# Get a free key at https://unsplash.com/developers
# VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Optional: Gemini AI for resume bullet writing (FREE — 1,500 calls/day, 15/min)
# Get a free API key at: https://aistudio.google.com/app/apikey
# Once set, the Resume Builder shows an "AI write bullets" button on each project entry
# that uses Gemini 1.5 Flash to write proper STAR-formula bullets from your project description.
# VITE_GEMINI_API_KEY=your_gemini_api_key
